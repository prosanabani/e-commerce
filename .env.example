# Shared
NODE_ENV=development

# TanStack Start
PORT=3000

# Bagisto backend (Laravel eCommerce)
BAGISTO_PORT=8000
BAGISTO_ENDPOINT=http://localhost:8000

# Exposed to the TanStack Start browser bundle
VITE_BAGISTO_ENDPOINT=http://localhost:8000
VITE_BAGISTO_STOREFRONT_KEY=

# PostgreSQL (used by Bagisto — create this database before bagisto:install)
# DB name defaults to "bagisto" — see apps/bagisto/scripts/env.postgres.example

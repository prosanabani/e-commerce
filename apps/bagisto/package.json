    "lint": "echo \"Bagisto uses Laravel Pint — run: composer pint\"",
    "typecheck": "echo \"Bagisto is a PHP app — no TypeScript typecheck\"",
    "format": "echo \"Bagisto uses Laravel Pint — run: composer pint\"",
    "build": "echo \"Bagisto backend has no Node build step\""
  }

{
  "name": "@repo/bagisto",
  "private": true,
  "scripts": {
    "setup": "node ./scripts/init.mjs",
    "bootstrap": "node ./scripts/setup.mjs",
    "postbootstrap": "node ./scripts/init.mjs",
    "migrate": "node ./scripts/migrate.mjs",
    "seed": "node ./scripts/seed.mjs",
    "fresh": "node ./scripts/fresh.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:sail": "docker compose up",
    "dev:down": "docker compose down",
    "install:api": "php artisan bagisto-api-platform:install --no-interaction",

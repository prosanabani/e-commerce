{
  "extends": "@repo/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@utils/*": ["./src/utils/*"],
      "@lib/*": ["./src/lib/*"],
      "@graphql/*": ["./src/graphql/*"],
      "@types/*": ["./src/types/*"],
      "@store/*": ["./src/store/*"],
      "next/link": ["./src/lib/next-compat/link.tsx"],
      "next/image": ["./src/lib/next-compat/image.tsx"],
      "next/navigation": ["./src/lib/next-compat/navigation.ts"],
      "next/dynamic": ["./src/lib/next-compat/dynamic.tsx"],
      "next/cache": ["./src/lib/next-compat/cache.ts"],
      "next/headers": ["./src/lib/next-compat/headers.ts"],
      "next/font/google": ["./src/lib/next-compat/font.ts"],
      "next/server": ["./src/lib/next-compat/server.ts"],
      "next/og": ["./src/lib/next-compat/og.ts"],
      "next-auth/react": ["./src/lib/auth/client.tsx"],
      "@repo/ui": ["../../packages/ui/src/index.ts"],
      "@repo/ui/src": ["../../packages/ui/src"],
      "@repo/ui/src/*": ["../../packages/ui/src/*"],
      "@repo/ui/components": ["../../packages/ui/src/components"],
      "@repo/ui/components/*": ["../../packages/ui/src/components/*"],
      "@repo/ui/hooks": ["../../packages/ui/src/hooks"],
      "@repo/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@repo/ui/lib": ["../../packages/ui/src/lib"],
      "@repo/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@repo/ui/*": ["../../packages/ui/src/components/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
